# git ignore 规则

# IDE / 编辑器临时文件
*.artifact.json
moz*-image.png

# 原始抓取数据（体积大、含用户信息）
data/crawl/
data/analysis/

# 数据库文件
data/app.db
data/*.db

# 环境变量
.env
.env.*

# 图库图片（体积大，不入 git）
assets/*
!assets/.gitkeep

# MediaCrawler 运行时数据
tools/MediaCrawler/data/
tools/MediaCrawler/browser_data/
tools/MediaCrawler/.env
tools/MediaCrawler/logs/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
dist/
build/
*.egg-info/

# 日志
*.log

# macOS
.DS_Store
data/publish_staging/

# 多账号浏览器登录态（含 Chromium user_data_dir，体积大、含敏感 cookie）
data/browser_profiles/
