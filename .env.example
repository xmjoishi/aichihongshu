# MiniMax Token Plan API
# 订阅地址：https://platform.minimaxi.com/subscribe/token-plan
# Key 获取：https://platform.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=your_token_plan_api_key_here

# Anthropic 兼容接口（用于文本生成，不支持图片）
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# 文本生成模型（Anthropic 兼容接口）
MINIMAX_TEXT_MODEL=MiniMax-M2.7

# 图片分析模型（通过 /v1/coding_plan/vlm 原生接口，与 MCP understand_image 相同底层）
# Token Plan 的 Anthropic/OpenAI 兼容接口均不支持图片输入，须使用此原生接口
MINIMAX_VISION_MODEL=MiniMax-M2.7

# 数据库路径（默认 data/app.db，相对项目根目录）
DB_PATH=data/app.db

# 图片存储目录（默认 assets/，相对项目根目录）
ASSETS_DIR=assets
